#!/usr/bin/env python

import sys
import curses
import logging
import argparse
from smount.smount import SerialMounter

try:
    import readline
    HAS_READLINE = True
except ImportError:
    HAS_READLINE = False

logger = logging.getLogger("smount")

# pylint: disable=too-few-public-methods
class SmountCompleter:
    def __init__(self, options):
        self.options = sorted(options)
        self.matches = []

    def complete(self, text, state):
        response = None
        if state == 0:
            if text:
                self.matches = [s for s in self.options if s and s.startswith(text)]
            else:
                self.matches = self.options[:]
        try:
            response = self.matches[state]
        except IndexError:
            response = None
        return response

def configure_logging(verbose_count, quiet):
    if quiet:
        level = logging.ERROR
    elif verbose_count > 0:
        level = logging.DEBUG
    else:
        level = logging.INFO

    # Custom format: simple messages for general log levels, structured for debug
    if level == logging.DEBUG:
        log_format = "%(asctime)s [%(levelname)s] %(name)s: %(message)s"
    else:
        log_format = "%(message)s"

    logging.basicConfig(level=level, format=log_format, stream=sys.stderr)

def log(command, arg, message, is_error=False):
    msg = f"Calling {command} with '{arg if arg else 'no argument'}': {message}"
    if is_error:
        logger.error(msg)
    else:
        logger.info(msg)

# pylint: disable-next=too-many-branches
def execute(mounter, command, arg) -> int:
    ret = 99
    if command == "list":
        available = mounter.get_mount_points()
        for i in available:
            print(f"{i}")
        ret = 0
    elif command == "mount":
        mount = mounter.get(arg)
        if mount is None:
            log(command, arg, 'mountpoint could not be found with that name', is_error=True)
            ret = 127
        elif mount.ismounted():
            log(command, arg, 'is already mounted')
            ret = 0
        elif mount.mount():
            log(command, arg, 'success 🎉')
            ret = 0
        else:
            log(command, arg, 'failed to mount', is_error=True)
            ret = 1
    elif command == "help":
        print("Available commands: list, mount, unmount")
        ret = 0
    elif command in ["umount", "unmount"]:
        mount = mounter.get(arg)
        if mount is None:
            log(command, arg, 'mountpoint could not be found with that name', is_error=True)
            ret = 127
        elif not mount.ismounted():
            log(command, arg, 'is not mounted already')
            ret = 0
        elif mount.unmount():
            log(command, arg, 'success 🎉')
            ret = 0
        else:
            log(command, arg, 'failed to unmount', is_error=True)
            ret = 1
    else:
        log(command, arg, "unknown command was used", is_error=True)
        ret = 2

    return ret

def interactive_prompter(prompt_text):
    old_completer = None
    if HAS_READLINE:
        old_completer = readline.get_completer()
        # Enable default filename completion if prompting for paths/folders
        path_keywords = ["path", "file", "target", "src", "dir", "folder"]
        if any(k in prompt_text.lower() for k in path_keywords):
            readline.set_completer_delims(' \t\n;')
            readline.parse_and_bind("tab: complete")
            readline.set_completer(None)
        else:
            readline.set_completer(None)

    try:
        val = input(prompt_text)
        if HAS_READLINE and val:
            readline.add_history(val)
        return val
    finally:
        if HAS_READLINE:
            readline.set_completer(old_completer)

# pylint: disable=too-many-branches
def run_interactive(mounter):
    mount_points = mounter.get_mount_points()

    if HAS_READLINE:
        options = ['q', 'r', 'quit', 'refresh']
        options += [p.name for p in mount_points]
        options += [str(i) for i in range(len(mount_points))]
        completer = SmountCompleter(options)
        readline.set_completer(completer.complete)
        readline.parse_and_bind('tab: complete')

    while True:
        for i, mount_point in enumerate(mount_points):
            print(f"{i} - {mount_point}")

        try:
            selected = input("select> ")
            if HAS_READLINE and selected:
                readline.add_history(selected)
        except KeyboardInterrupt:
            selected = 'q'  # CTRL-C
        except EOFError:
            selected = 'q'  # CTRL-D

        if selected in ['q', 'quit']:
            sys.exit(0)
        if selected in ['r', 'refresh', '']:
            mounter.refresh_config()
            mount_points = mounter.get_mount_points()
            if HAS_READLINE:
                options = ['q', 'r', 'quit', 'refresh']
                options += [p.name for p in mount_points]
                options += [str(i) for i in range(len(mount_points))]
                readline.set_completer(SmountCompleter(options).complete)
            continue

        point = mounter.get(selected)
        if point is None:
            try:
                idx = int(selected)
                if 0 <= idx < len(mount_points):
                    point = mount_points[idx]
                else:
                    print(f"Selection is invalid: '{selected}' is not within range")
                    continue
            except ValueError:
                print(f"Selection is invalid: '{selected}' is not "
                      "a valid mountpoint name or index")
                continue

        prompter_fn = interactive_prompter if HAS_READLINE else None
        if not point.toggle(prompter=prompter_fn):
            print("There was an error processing mount/unmount of the mountpoint")

# pylint: disable=too-many-statements
def run_tui(mounter):
    # pylint: disable=too-many-branches,too-many-locals
    def main_loop(stdscr):
        try:
            curses.curs_set(0)
        except curses.error:
            pass

        stdscr.keypad(True)

        try:
            curses.start_color()
            curses.use_default_colors()
            curses.init_pair(1, curses.COLOR_GREEN, -1)
            curses.init_pair(2, curses.COLOR_RED, -1)
            has_colors = True
        except curses.error:
            has_colors = False

        selected_idx = 0
        message = ""

        while True:
            stdscr.clear()
            height, width = stdscr.getmaxyx()

            # Header
            stdscr.addstr(0, 0, "smount - Mountpoint Manager (TUI)", curses.A_BOLD)
            stdscr.addstr(1, 0, "[Up/Down] Navigate  [Enter] Toggle  [R] Refresh  [Q] Quit",
                         curses.A_DIM)
            stdscr.addstr(2, 0, "-" * (width - 1))

            mount_points = mounter.get_mount_points()
            if not mount_points:
                stdscr.addstr(4, 2, "No mountpoints defined.")
            else:
                for idx, mp in enumerate(mount_points):
                    is_mounted = mp.ismounted()
                    status_indicator = "🟢" if is_mounted else "🔴"
                    mp_str = (
                        f" {status_indicator} {mp.name} : "
                        f"{mp.config.get('src')} => {mp.config.get('target')} "
                        f"[{mp.config.get('type')}]"
                    )

                    attr = 0
                    if idx == selected_idx:
                        attr |= curses.A_REVERSE
                    elif has_colors:
                        if is_mounted:
                            attr |= curses.color_pair(1)
                        else:
                            attr |= curses.color_pair(2)

                    display_str = mp_str[:width - 4]
                    stdscr.addstr(4 + idx, 2, display_str, attr)

            # Footer
            if message:
                stdscr.addstr(height - 2, 0, "-" * (width - 1))
                stdscr.addstr(height - 1, 0, message[:width - 1], curses.A_BOLD)

            stdscr.refresh()

            try:
                key = stdscr.getch()
            except KeyboardInterrupt:
                break

            if key == ord('q') or key == ord('Q'):
                break
            if key == ord('r') or key == ord('R'):
                mounter.refresh_config()
                message = "Config refreshed."
                selected_idx = max(0, min(selected_idx, len(mounter.get_mount_points()) - 1))
            elif key == curses.KEY_UP:
                if selected_idx > 0:
                    selected_idx -= 1
                    message = ""
            elif key == curses.KEY_DOWN:
                if selected_idx < len(mount_points) - 1:
                    selected_idx += 1
                    message = ""
            elif key in [curses.KEY_ENTER, 10, 13]:
                if not mount_points:
                    continue
                point = mount_points[selected_idx]

                def tui_prompter(prompt_text):
                    try:
                        curses.curs_set(1)
                    except curses.error:
                        pass
                    h, w = stdscr.getmaxyx()
                    stdscr.addstr(h - 1, 0, prompt_text[:w - 1])
                    stdscr.clrtoeol()
                    stdscr.refresh()
                    curses.echo()
                    try:
                        val = stdscr.getstr(h - 1, len(prompt_text)).decode('utf-8')
                    except (UnicodeDecodeError, curses.error):
                        val = ""
                    curses.noecho()
                    try:
                        curses.curs_set(0)
                    except curses.error:
                        pass
                    return val

                message = f"Processing toggle for {point.name}..."
                stdscr.refresh()

                try:
                    success = point.toggle(prompter=tui_prompter)
                    if success:
                        message = f"Successfully toggled {point.name}."
                    else:
                        message = f"Failed to toggle {point.name}."
                except Exception as e:  # pylint: disable=broad-exception-caught
                    message = f"Error toggling {point.name}: {e}"

    curses.wrapper(main_loop)

def main(argv):
    parser = argparse.ArgumentParser(
        description="smount - A mountpoint Manager",
        add_help=False  # Allow custom handling of help command if needed, or bypass standard -h
    )
    # We add custom help flag to avoid conflict with 'help' command if needed
    parser.add_argument("-v", "--verbose", action="count", default=0,
                        help="Increase verbosity level (e.g. -v for debug logging)")
    parser.add_argument("-q", "--quiet", action="store_true",
                        help="Quiet mode (only print errors)")
    parser.add_argument("-h", "--help", action="help", help="show this help message and exit")
    parser.add_argument("command", nargs="?",
                        help="Command: list, mount, unmount, umount, tui, help")
    parser.add_argument("arg", nargs="?",
                        help="Argument for command (e.g. mountpoint name)")

    args = parser.parse_args(argv[1:])
    configure_logging(args.verbose, args.quiet)

    mounter = SerialMounter()

    if args.command is None:
        run_interactive(mounter)
        return

    if args.command == "tui":
        run_tui(mounter)
        return

    sys.exit(execute(mounter, args.command, args.arg))

if __name__ == "__main__":
    try:
        # execute only if run as a script
        main(sys.argv)
    except RuntimeError as e:
        logger.error("An exception occurred: %s", e)
        sys.exit(1)
